{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/laiyanlong/us-stocks-daily-report/main/schemas/data.schema.json",
  "$schemaVersion": "1.0.0",
  "title": "US Stocks Daily Report — Dashboard Data",
  "description": "Aggregate dashboard payload consumed by the DappGo US Stocks mobile app and web viewer.",
  "type": "object",
  "required": ["last_updated", "tickers", "ticker_data", "sector_rotation"],
  "additionalProperties": true,

  "properties": {
    "last_updated": {
      "type": "string",
      "description": "Date of this snapshot (YYYY-MM-DD, US Eastern Time)."
    },
    "tickers": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[A-Z][A-Z0-9.\\-]{0,9}$" }
    },
    "ticker_data": {
      "type": "object",
      "description": "Map of ticker → analysis dict",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "symbol":           { "type": "string" },
          "name":             { "type": "string" },
          "sector":           { "type": "string" },
          "price_change_pct": { "type": "number" },
          "price_history": {
            "type": "array",
            "description": "Last ~250 trading days of OHLCV for chart rendering + client-side MA60/MA200 + timeframe toggles.",
            "items": {
              "type": "object",
              "required": ["date", "close"],
              "properties": {
                "date":   { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
                "close":  { "type": "number" },
                "high":   { "type": "number" },
                "low":    { "type": "number" },
                "volume": { "type": "integer" }
              }
            }
          },
          "indicators": {
            "type": "object",
            "properties": {
              "latest_close":    { "type": ["number", "null"] },
              "ma_5":            { "type": ["number", "null"] },
              "ma_10":           { "type": ["number", "null"] },
              "ma_20":           { "type": ["number", "null"] },
              "ma_60":           { "type": ["number", "null"] },
              "ma_120":          { "type": ["number", "null"] },
              "ma_200":          { "type": ["number", "null"] },
              "ma_200_slope":    { "type": ["number", "null"] },
              "rsi_14":          { "type": ["number", "null"] },
              "macd": {
                "type": "object",
                "properties": {
                  "macd":   { "type": ["number", "null"] },
                  "signal": { "type": ["number", "null"] },
                  "hist":   { "type": ["number", "null"] }
                }
              },
              "kd": {
                "type": "object",
                "properties": {
                  "k": { "type": ["number", "null"] },
                  "d": { "type": ["number", "null"] }
                }
              },
              "bollinger": {
                "type": "object",
                "properties": {
                  "upper":     { "type": ["number", "null"] },
                  "mid":       { "type": ["number", "null"] },
                  "lower":     { "type": ["number", "null"] },
                  "bandwidth": { "type": ["number", "null"] }
                }
              },
              "hv_20":         { "type": ["number", "null"] },
              "volume_today":  { "type": ["number", "null"] },
              "volume_5d_avg": { "type": ["number", "null"] }
            }
          },
          "ownership": {
            "type": "object",
            "description": "US-specific institutional + insider data (replaces TW 三大法人/融資融券).",
            "properties": {
              "institutional_pct": {
                "type": ["number", "null"],
                "description": "% of float held by institutions (yfinance institutionOwnership)."
              },
              "insider_net_30d": {
                "type": "string",
                "enum": ["buying", "selling", "mixed", "none"],
                "description": "Net direction of insider Form 4 transactions over the past 30 days."
              },
              "insider_transactions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "date":      { "type": "string", "format": "date" },
                    "insider":   { "type": "string" },
                    "title":     { "type": "string" },
                    "type":      { "type": "string", "enum": ["buy", "sell", "other"] },
                    "shares":    { "type": "integer" },
                    "value_usd": { "type": ["number", "null"] }
                  }
                }
              }
            }
          },
          "earnings_date_next": {
            "type": ["string", "null"],
            "description": "Next earnings call date (YYYY-MM-DD) from yfinance.calendar."
          },
          "filings_recent": {
            "type": "array",
            "description": "Recent SEC EDGAR 8-K and other filings (best-effort, may be empty).",
            "items": {
              "type": "object",
              "properties": {
                "type":  { "type": "string", "description": "8-K, 10-Q, 10-K, etc." },
                "date":  { "type": "string", "format": "date" },
                "title": { "type": "string" },
                "url":   { "type": "string", "format": "uri" }
              }
            }
          },
          "news": {
            "type": "array",
            "description": "Recent news headlines for this ticker (yfinance + Finnhub merged, may be empty).",
            "items": {
              "type": "object",
              "properties": {
                "title":   { "type": "string" },
                "url":     { "type": "string" },
                "source":  { "type": "string" },
                "date":    { "type": "string" },
                "summary": { "type": "string" }
              }
            }
          },
          "news_commentary": {
            "type": "string",
            "description": "AI-generated 2-3 sentence Traditional Chinese summary of recent news. Only present when AI generated one."
          },
          "signals": {
            "type": "object",
            "properties": {
              "trend_label":      { "type": "string" },
              "trend_reason":     { "type": "string" },
              "momentum_label":   { "type": "string" },
              "momentum_reason":  { "type": "string" },
              "volume_label":     { "type": "string" },
              "volume_reason":    { "type": "string" },
              "ownership_label":  { "type": "string" },
              "ownership_reason": { "type": "string" },
              "verdict":          { "type": "string", "enum": ["BUY","HOLD","WATCH","AVOID","SELL"] },
              "verdict_reason":   { "type": "string" }
            }
          }
        }
      }
    },
    "sector_rotation": {
      "type": "object",
      "description": "Per-sector aggregate. Keys are GICS sector names from config/tickers.yaml.",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "tickers":        { "type": "array", "items": { "type": "string" } },
          "avg_change_pct": { "type": "number" },
          "top_gainer":     { "type": "object" },
          "top_loser":      { "type": "object" },
          "avg_rsi":        { "type": ["number", "null"] },
          "verdict":        { "type": "string", "enum": ["HOT","WARM","NEUTRAL","COOL","COLD"] },
          "verdict_reason": { "type": "string" }
        }
      }
    },
    "sector_correlation": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "sector_a":    { "type": "string" },
          "sector_b":    { "type": "string" },
          "correlation": { "type": "number" },
          "direction":   { "type": "string" }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "description": "Engine-curated buy candidates (low-risk + below MA + momentum-turning). Up to 5.",
      "items": {
        "type": "object",
        "properties": {
          "symbol":       { "type": "string" },
          "name":         { "type": "string" },
          "sector":       { "type": "string" },
          "reason":       { "type": "string" },
          "score":        { "type": "integer" },
          "signals":      { "type": "array", "items": { "type": "string" } },
          "latest_close": { "type": "number" },
          "rsi":          { "type": ["number", "null"] },
          "hv_20":        { "type": ["number", "null"] }
        }
      }
    },
    "cautions": {
      "type": "array",
      "description": "Warning list — verdicts SELL/AVOID, or RSI≥70 with insiders selling. Up to 5.",
      "items": {
        "type": "object",
        "properties": {
          "symbol":       { "type": "string" },
          "name":         { "type": "string" },
          "sector":       { "type": "string" },
          "reason":       { "type": "string" },
          "verdict":      { "type": "string" },
          "signals":      { "type": "array", "items": { "type": "string" } },
          "latest_close": { "type": "number" },
          "rsi":          { "type": ["number", "null"] }
        }
      }
    }
  }
}
